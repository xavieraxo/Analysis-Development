@* Animación minimalista: viajero con sombrero cónico, vara y bolsa; dos posturas de piernas que se alternan al caminar. *@
<div class="chat-thinking-animation">
    <div class="chat-thinking-track" aria-hidden="true">
        @* Frame A: piernas abiertas (se muestra dos veces por ciclo) *@
        <div class="chat-thinking-frame chat-thinking-frame-a">
            <svg class="chat-thinking-character" viewBox="0 0 70 65" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Procesando respuesta">
                <g class="hat"><path d="M22 18 L35 8 L48 18 L35 28 Z" fill="#4a4a4a" stroke="#3d3d3d" stroke-width="0.8"/></g>
                <circle cx="35" cy="32" r="7" fill="#5c5c5c" stroke="#4a4a4a" stroke-width="0.6"/>
                <path d="M28 40 L30 52 L40 52 L42 40 Z" fill="#5c5c5c" stroke="#4a4a4a" stroke-width="0.5"/>
                <g class="legs">
                    <line x1="31" y1="52" x2="28" y2="62" stroke="#4a4a4a" stroke-width="2" stroke-linecap="round"/>
                    <line x1="39" y1="52" x2="42" y2="62" stroke="#4a4a4a" stroke-width="2" stroke-linecap="round"/>
                </g>
                <g class="stick"><line x1="42" y1="38" x2="62" y2="22" stroke="#6b5344" stroke-width="2" stroke-linecap="round"/></g>
                <g class="bag"><ellipse cx="62" cy="26" rx="5" ry="6" fill="#6b6b6b" stroke="#5c5c5c" stroke-width="0.6"/></g>
            </svg>
        </div>
        @* Frame B: piernas más cerradas (se muestra dos veces por ciclo) *@
        <div class="chat-thinking-frame chat-thinking-frame-b">
            <svg class="chat-thinking-character" viewBox="0 0 70 65" xmlns="http://www.w3.org/2000/svg">
                <g class="hat"><path d="M22 18 L35 8 L48 18 L35 28 Z" fill="#4a4a4a" stroke="#3d3d3d" stroke-width="0.8"/></g>
                <circle cx="35" cy="32" r="7" fill="#5c5c5c" stroke="#4a4a4a" stroke-width="0.6"/>
                <path d="M28 40 L30 52 L40 52 L42 40 Z" fill="#5c5c5c" stroke="#4a4a4a" stroke-width="0.5"/>
                <g class="legs">
                    <line x1="32" y1="52" x2="32" y2="62" stroke="#4a4a4a" stroke-width="2" stroke-linecap="round"/>
                    <line x1="38" y1="52" x2="38" y2="62" stroke="#4a4a4a" stroke-width="2" stroke-linecap="round"/>
                </g>
                <g class="stick"><line x1="42" y1="38" x2="62" y2="22" stroke="#6b5344" stroke-width="2" stroke-linecap="round"/></g>
                <g class="bag"><ellipse cx="62" cy="26" rx="5" ry="6" fill="#6b6b6b" stroke="#5c5c5c" stroke-width="0.6"/></g>
            </svg>
        </div>
    </div>
</div>
