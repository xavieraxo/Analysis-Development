@page "/reset-password"
@using Microsoft.AspNetCore.WebUtilities
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Restablecer contraseña</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-12">
    <MudPaper Elevation="3" Class="pa-6">
        <MudText Typo="Typo.h5" GutterBottom="true" Align="Align.Center">Crea una nueva contraseña</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
            Ingresa el código recibido y tu nueva contraseña.
        </MudText>

        <MudForm @ref="_form" OnValidSubmit="SubmitReset" Class="mt-4">
            <MudTextField @bind-Value="_email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="InputType.Email"
                          Required="true"
                          For="@(() => _email)" />

            <MudTextField @bind-Value="_code"
                          Label="Código"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="InputType.Text"
                          MaxLength="6"
                          Required="true"
                          For="@(() => _code)" />

            <MudTextField @bind-Value="_password"
                          Label="Nueva contraseña"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="InputType.Password"
                          Required="true"
                          For="@(() => _password)" />

            <MudTextField @bind-Value="_confirm"
                          Label="Confirmar contraseña"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="InputType.Password"
                          Required="true"
                          For="@(() => _confirm)" />

            <MudButton Type="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-4"
                       Disabled="_loading">
                @(_loading ? "Actualizando..." : "Actualizar contraseña")
            </MudButton>
        </MudForm>

        @if (!string.IsNullOrEmpty(_message))
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">@_message</MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    private string _email = string.Empty;
    private string _code = string.Empty;
    private string _password = string.Empty;
    private string _confirm = string.Empty;
    private bool _loading;
    private string _message = string.Empty;
    private MudForm? _form;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("email", out var emailParam))
        {
            _email = emailParam.ToString();
        }
        if (query.TryGetValue("code", out var codeParam))
        {
            _code = codeParam.ToString();
        }
    }

    private async Task SubmitReset()
    {
        if (_form is null) return;
        await _form.Validate();
        if (!_form.IsValid) return;

        if (_password != _confirm)
        {
            Snackbar.Add("Las contraseñas no coinciden", Severity.Error);
            return;
        }

        _loading = true;
        try
        {
            await ApiService.PostAsync<object>("/api/auth/reset-password", new { Email = _email, Code = _code, NewPassword = _password });
            _message = "Tu contraseña fue actualizada con éxito. Ahora puedes iniciar sesión.";
            Snackbar.Add(_message, Severity.Success);
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"No se pudo actualizar la contraseña: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}

