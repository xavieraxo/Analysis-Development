@page "/forgot-password"
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Recuperar contraseña</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-12">
    <MudPaper Elevation="3" Class="pa-6">
        <MudText Typo="Typo.h5" GutterBottom="true" Align="Align.Center">¿Olvidaste tu contraseña?</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
            Ingresa tu email y te enviaremos un código de 6 caracteres para continuar.
        </MudText>

        <MudForm @ref="_form" OnValidSubmit="SendEmail" Class="mt-4">
            <MudTextField @bind-Value="_email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="InputType.Email"
                          Required="true"
                          For="@(() => _email)" />

            <MudButton Type="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-4"
                       Disabled="_loading">
                @(_loading ? "Enviando..." : "Enviar código")
            </MudButton>
        </MudForm>

        @if (!string.IsNullOrEmpty(_message))
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">@_message</MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    private string _email = string.Empty;
    private bool _loading;
    private string _message = string.Empty;
    private MudForm? _form;

    private async Task SendEmail()
    {
        if (_form is null)
            return;

        await _form.Validate();
        if (!_form.IsValid) return;

        _loading = true;
        try
        {
            await ApiService.PostAsync<object>("/api/auth/forgot-password", new { Email = _email });
            _message = "Si el email existe, se enviará un código de recuperación.";
            Snackbar.Add(_message, Severity.Info);
            Navigation.NavigateTo($"/verify-code?email={Uri.EscapeDataString(_email)}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al solicitar código: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}

